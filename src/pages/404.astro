
---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="404 — Not Found" description="The page you’re looking for doesn’t exist.">
  <section class="qf-sec qf-sec--hero qf-center">
    <div class="qf-wrap">
      <h1 class="qf-h1">404 — Not Found</h1>
      <p class="qf-muted">The page you’re looking for doesn’t exist or has been moved.</p>
      <a class="qf-btn" href="/">Back to Home</a>
    </div>
  </section>
</BaseLayout>
