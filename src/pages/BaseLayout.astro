---
export interface Props {
  title?: string;
  description?: string;
}
const { title = "QiFlow", description = "QiFlow site" } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <!-- Estilos globales -->
    /global.css
  </head>
  <body>
    <main>
      <slot />
    </main>
  </body>
</html>
